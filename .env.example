# Postgres connection (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Google OAuth credentials from console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# The full URL of your deployed app (Railway will give you one)
# Used for the OAuth redirect. No trailing slash.
APP_URL=https://your-app.up.railway.app

# The bestellingen-Gmail address that is allowed to log in.
# Only this email will be granted access to the tracker.
ALLOWED_EMAIL=melanie.bestellingen@gmail.com

# Random string for cookie signing — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# How often to scan Gmail (minutes). Default 15.
SCAN_INTERVAL_MINUTES=15

# Gmail search query. Restrict to a label for safety.
# Example with label: label:bestellingen
# Example with keywords: (subject:(bestelling OR order OR confirmation) OR from:(noreply OR orders))
GMAIL_QUERY=label:bestellingen newer_than:90d

# 17track.net API key — voor automatische status-checks van tracking codes.
# Maak een gratis account op https://api.17track.net en pak je API key uit het dashboard.
# Gratis tier: 100 zendingen per maand. Laat leeg om uit te zetten.
SEVENTEEN_TRACK_KEY=
